<Window x:Class="ToiseApp.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contrôle Toise — Linak DL14"
        Height="520"
        Width="400"
        MinHeight="480"
        MinWidth="380"
        Background="#F0F2F5"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Couleurs -->
        <Color x:Key="AccentColor">#2563EB</Color>
        <Color x:Key="DangerColor">#DC2626</Color>
        <Color x:Key="SuccessColor">#16A34A</Color>
        <Color x:Key="WarningColor">#D97706</Color>

        <SolidColorBrush x:Key="AccentBrush"
                Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="DangerBrush"
                Color="{StaticResource DangerColor}"/>
        <SolidColorBrush x:Key="SuccessBrush"
                Color="{StaticResource SuccessColor}"/>

        <!-- Style bouton principal -->
        <Style x:Key="PrimaryButton"
                TargetType="Button">
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="Background"
                    Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="12,8"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Opacity"
                                        Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                    Value="False">
                                <Setter Property="Opacity"
                                        Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style bouton Stop (rouge) -->
        <Style x:Key="StopButton"
                TargetType="Button"
                BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background"
                    Value="{StaticResource DangerBrush}"/>
        </Style>

        <!-- Style bouton Reconnecter (neutre) -->
        <Style x:Key="SecondaryButton"
                TargetType="Button"
                BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background"
                    Value="#64748B"/>
        </Style>

        <!-- Card container -->
        <Style x:Key="Card"
                TargetType="Border">
            <Setter Property="Background"
                    Value="White"/>
            <Setter Property="CornerRadius"
                    Value="10"/>
            <Setter Property="Padding"
                    Value="16"/>
            <Setter Property="Margin"
                    Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8"
                            ShadowDepth="1"
                            Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Titre -->
            <RowDefinition Height="Auto"/>
            <!-- Carte hauteur courante -->
            <RowDefinition Height="Auto"/>
            <!-- Carte contrôle manuel -->
            <RowDefinition Height="Auto"/>
            <!-- Carte déplacement cible -->
            <RowDefinition Height="Auto"/>
            <!-- Carte pas + reconnecter -->
            <RowDefinition Height="*"/>
            <!-- Barre de statut -->
        </Grid.RowDefinitions>

        <!-- ── Titre ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="0,0,0,12">
            <Ellipse Width="12"
                    Height="12"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center">
                <Ellipse.Fill>
                    <SolidColorBrush Color="{StaticResource SuccessColor}"/>
                </Ellipse.Fill>
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnected}"
                                    Value="False">
                                <Setter Property="Fill"
                                        Value="{StaticResource DangerBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="Contrôle Toise — Linak DL14"
                       FontSize="18"
                    FontWeight="Bold"
                    Foreground="#1E293B"/>
        </StackPanel>

        <!-- ── Carte : Hauteur courante ───────────────────────────────────── -->
        <Border Grid.Row="1"
                Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="POSITION ACTUELLE"
                           FontSize="11"
                        FontWeight="SemiBold"
                           Foreground="#94A3B8"/>
                <TextBlock Text="{Binding CurrentHeightMm, StringFormat={}{0:F0} mm}"
                           FontSize="48"
                        FontWeight="Bold"
                        Foreground="#1E293B"
                           HorizontalAlignment="Center"
                        Margin="0,4,0,0"/>
                <TextBlock Text="{Binding CurrentHeightCm}"
                           FontSize="16"
                        Foreground="#64748B"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Carte : Contrôle manuel ────────────────────────────────────── -->
        <Border Grid.Row="2"
                Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="CONTRÔLE MANUEL"
                           FontSize="11"
                        FontWeight="SemiBold"
                           Foreground="#94A3B8"
                        Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- MONTER -->
                    <Button Grid.Column="0"
                            Content="▲  Monter"
                            Command="{Binding MoveUpCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="48"/>

                    <!-- STOP -->
                    <Button Grid.Column="2"
                            Content="■  Stop"
                            Command="{Binding StopCommand}"
                            Style="{StaticResource StopButton}"
                            Height="48"/>

                    <!-- DESCENDRE -->
                    <Button Grid.Column="4"
                            Content="▼  Descendre"
                            Command="{Binding MoveDownCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="48"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Carte : Déplacement cible ─────────────────────────────────── -->
        <Border Grid.Row="3"
                Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="DÉPLACEMENT VERS UNE HAUTEUR CIBLE"
                           FontSize="11"
                        FontWeight="SemiBold"
                           Foreground="#94A3B8"
                        Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding TargetHeightMm, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16"
                            Padding="10,8"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E1"
                            BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="White"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <ScrollViewer x:Name="PART_ContentHost"
                                                              Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Grid.Column="2"
                            Text="mm"
                               FontSize="14"
                            Foreground="#64748B"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="4"
                            Content="Aller"
                            Command="{Binding MoveToCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="80"
                            Height="38"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Carte : Pas + Boutons pas + Reconnecter ───────────────────── -->
        <Border Grid.Row="4"
                Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Pas de déplacement -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="PAS DE DÉPLACEMENT"
                               FontSize="11"
                            FontWeight="SemiBold"
                               Foreground="#94A3B8"
                            Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="-"
                                Command="{Binding StepDownCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Height="36"
                                FontSize="18"/>

                        <TextBox Grid.Column="2"
                                 Text="{Binding StepMm, UpdateSourceTrigger=PropertyChanged}"
                                 Width="70"
                                FontSize="14"
                                Padding="6,4"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="#CBD5E1"
                                BorderThickness="1">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="White"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Grid.Column="2"
                                Text="mm"
                                   FontSize="11"
                                Foreground="#94A3B8"
                                   HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                   Margin="0,0,4,2"/>

                        <Button Grid.Column="4"
                                Content="+"
                                Command="{Binding StepUpCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Height="36"
                                FontSize="18"/>
                    </Grid>
                </StackPanel>

                <!-- Reconnexion -->
                <Button Grid.Column="2"
                        Content="Reconnecter"
                        Command="{Binding ReconnectCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Width="110"
                        Height="36"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- ── Barre de statut ────────────────────────────────────────────── -->
        <Border Grid.Row="5"
                VerticalAlignment="Bottom"
                Background="White"
                CornerRadius="6"
                Padding="12,8">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                    Foreground="#475569"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
